---
import site from "@/lib/site";
const b = site.business;
const facts = [
  b.hours && { k: "Erreichbar", v: b.hours },
  b.areas?.length && { k: "Einsatzgebiet", v: b.areas.join(" · ") },
  b.branche && { k: "Fachgebiet", v: b.branche },
].filter(Boolean) as { k: string; v: string }[];
---
{site.about ? (
  <section class="about">
    <div class="wrap about-in">
      <div>
        <span class="eyebrow">Über uns</span>
        <h2>{b.name}</h2>
        <p class="body">{site.about}</p>
      </div>
      {facts.length ? (
        <aside class="facts">
          {facts.map((f) => (
            <div class="fact">
              <span class="fk">{f.k}</span>
              <span class="fv">{f.v}</span>
            </div>
          ))}
        </aside>
      ) : null}
    </div>
  </section>
) : null}
<style>
  .about { background: var(--surface); border-block: 1px solid var(--line); }
  .about-in { display: grid; gap: 44px; }
  @media (min-width: 860px) { .about-in { grid-template-columns: 1.4fr 1fr; align-items: start; } }
  .body { margin-top: 18px; font-size: 1.05rem; max-width: 56ch; }
  .facts { display: grid; gap: 2px; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .fact { padding: 20px 22px; display: flex; flex-direction: column; gap: 4px; background: var(--bg); }
  .fk { font-family: var(--font-display); font-size: .75rem; text-transform: uppercase; letter-spacing: .12em; color: var(--accent); font-weight: 600; }
  .fv { font-weight: 500; color: var(--ink); }
</style>
