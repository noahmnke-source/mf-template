---
import site from "@/lib/site";
const items = site.services ?? [];
---
{items.length ? (
  <section id="leistungen">
    <div class="wrap">
      <span class="eyebrow">Leistungen</span>
      <h2>Was wir für Sie tun</h2>
      <div class="grid grid-3" style="margin-top:38px">
        {items.map((s, i) => (
          <article class="card">
            <span class="num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
) : null}
<style>
  .num { font-family: var(--font-display); font-weight: 700; color: var(--accent); font-size: .85rem; letter-spacing: .1em; }
  .card h3 { margin: 14px 0 8px; }
</style>
